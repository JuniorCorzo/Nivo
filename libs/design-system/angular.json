{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "design-system": {
      "projectType": "library",
      "root": "",
      "sourceRoot": "src",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "ng-package.json",
            "tsConfig": "tsconfig.lib.json"
          }
        },
        "build-browser": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "dist/storybook-support",
            "index": "",
            "main": "src/storybook-main.ts",
            "tsConfig": "tsconfig.browser.json",
            "styles": [
              "node_modules/@ngxpert/hot-toast/src/styles/styles.css",
              "storybook.css"
            ],
            "assets": []
          }
        },
        "storybook": {
          "builder": "@storybook/angular:start-storybook",
          "options": {
            "configDir": ".storybook",
            "browserTarget": "design-system:build-browser",
            "tsConfig": "tsconfig.storybook.json",
            "port": 6006,
            "compodoc": false
          }
        },
        "build-storybook": {
          "builder": "@storybook/angular:build-storybook",
          "options": {
            "configDir": ".storybook",
            "browserTarget": "design-system:build-browser",
            "tsConfig": "tsconfig.storybook.json",
            "outputDir": "storybook-static",
            "compodoc": false
          }
        }
      }
    }
  },
  "cli": {
    "analytics": "0979dd68-6671-4c14-b144-da32514ad5a1"
  }
}
