{
  "name": "web",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "generated:api": "ng-openapi-gen --config ng-openapi-gen.json",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "engines": {
    "bun": "@1.3.11"
  },
  "packageManager": "bun@1.3.11",
  "dependencies": {
    "@angular/aria": "^21.2.6",
    "@angular/cdk": "^21.2.6",
    "@angular/common": "^21.2.6",
    "@angular/compiler": "^21.2.6",
    "@angular/core": "^21.2.6",
    "@angular/forms": "^21.2.6",
    "@angular/platform-browser": "^21.2.6",
    "@angular/router": "^21.2.6",
    "@ng-icons/core": "^33.2.0",
    "@ng-icons/lucide": "^33.2.0",
    "@ngneat/overview": "7.0.0",
    "@ngxpert/hot-toast": "6.1.0",
    "@nivo-sass/design-system": "workspace:*",
    "@tailwindcss/postcss": "^4.2.2",
    "leaflet": "1.9.4",
    "postcss": "^8.5.8",
    "rxjs": "~7.8.2",
    "tailwindcss": "^4.2.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.5",
    "@angular/cli": "^21.2.5",
    "@angular/compiler-cli": "^21.2.6",
    "@socketsecurity/bun-security-scanner": "1.1.2",
    "@types/jasmine": "~6.0.0",
    "@types/leaflet": "1.9.21",
    "jasmine-core": "~6.1.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.2.0",
    "ng-openapi-gen": "^1.0.5",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "~6.0.2"
  }
}
