{
  "installation": {
    "version": "21.6.4",
    "plugins": {
      "@nx/gradle": "21.6.4",
      "@nx/js": "21.6.4",
      "@nx/webpack": "21.6.4"
    }
  },
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "nxCloudId": "68eab4af773504607e893862",
  "plugins": [
    {
      "plugin": "@nx/gradle",
      "options": {
        "testTargetName": "test",
        "classesTargetName": "classes",
        "buildTargetName": "build"
      }
    },
    {
      "plugin": "@nx/js",
      "options": {
        "buildTargetName": "build",
        "lintTargetName": "lint",
        "testTargetName": "test"
      }
    }
  ],
  "targetDefaults": {
    "build": {
      "cache": true,
      "outputs": [
        "{projectRoot}/build"
      ]
    },
    "lint": {
      "cache": true,
      "inputs": [
        "default",
        "{workspaceRoot}/.eslintrc.json",
        "{workspaceRoot}/.eslintignore"
      ]
    },
    "test": {
      "cache": true,
      "inputs": [
        "default",
        "{workspaceRoot}/jest.config.js",
        "{workspaceRoot}/jest.preset.js"
      ]
    }
  },
  "namedInputs": {
    "default": [
      "{projectRoot}/**/*"
    ],
    "production": [
      "default",
      "!{projectRoot}/src/test/**/*"
    ]
  }
}
